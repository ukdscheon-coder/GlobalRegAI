# ============================================================
#  GlobalRegAI — Environment Configuration
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# ── Security Keys (change these!) ──────────────────────────
WEBUI_SECRET_KEY=globalregai-secret-change-me-2026
N8N_ENCRYPTION_KEY=globalregai-n8n-change-me-2026

# ── Ollama Model Settings ───────────────────────────────────
# Primary reasoning model (choose based on your RAM):
#   4GB  RAM → llama3.2:1b
#   8GB  RAM → llama3.2:3b  (recommended)
#   16GB RAM → llama3.1:8b
#   32GB RAM → llama3.1:70b (best quality)
PRIMARY_MODEL=llama3.2:3b

# Embedding model (for RAG — always use this)
EMBEDDING_MODEL=nomic-embed-text

# ── Service Ports ────────────────────────────────────────────
WEBUI_PORT=3000
N8N_PORT=5678
OLLAMA_PORT=11434
QDRANT_PORT=6333
SEARXNG_PORT=8080

# ── Optional: GPU Settings ───────────────────────────────────
# Set to 'true' if you have NVIDIA GPU (Windows/Linux)
USE_GPU=false
# For Apple Silicon Mac, GPU is used automatically via Metal

# ── Regulatory Data Sources (public APIs) ────────────────────
FDA_BASE_URL=https://api.fda.gov
FDA_DEVICE_URL=https://www.accessdata.fda.gov/scripts/cdrh/cfdocs/cfpmn/pmn.cfm
EMA_BASE_URL=https://www.ema.europa.eu/en
MFDS_BASE_URL=https://www.mfds.go.kr
ISO_BASE_URL=https://www.iso.org
